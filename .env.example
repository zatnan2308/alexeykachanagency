# Alexey Kachan Agency — environment variables template
# Copy this file to `.env` (or `.env.production` / `.env.development`) and fill in real values.
# All `PUBLIC_*` variables are exposed to the client; everything else is build-time only.
# DO NOT commit the real `.env` file (it's in .gitignore).

# -----------------------------------------------------------------------------
# Analytics — Google Tag Manager
# Loaded via Partytown (Web Worker) from BaseLayout.astro.
# Empty = scripts not injected, no analytics calls.
# -----------------------------------------------------------------------------
PUBLIC_GTM_ID=

# -----------------------------------------------------------------------------
# Analytics — Microsoft Clarity (heatmaps + session recordings)
# Gated behind cookie consent (analytics category). Loads only after opt-in.
# -----------------------------------------------------------------------------
PUBLIC_CLARITY_ID=

# -----------------------------------------------------------------------------
# Forms — Web3Forms (free tier, no backend needed)
# Used by: Contacts page, Brief website, Brief ads, Footer newsletter.
# PUBLIC key — safe to commit / appears in client code. It only routes form
# submissions to the inbox set in the Web3Forms account (mail@alexeykachan.com).
# A default is also baked into src/lib/web3forms.ts; this var overrides it.
# Manage the key at https://web3forms.com/
# -----------------------------------------------------------------------------
PUBLIC_WEB3FORMS_KEY=412b7e61-500f-47f4-ad97-264e6e9d2626

# -----------------------------------------------------------------------------
# Site URL (override only if deploying to a non-canonical preview domain)
# Default: https://alexeykachan.com (set in astro.config.mjs)
# -----------------------------------------------------------------------------
# SITE_URL=https://alexeykachan.com
