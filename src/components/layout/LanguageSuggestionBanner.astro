---
/**
 * LanguageSuggestionBanner.astro
 * ------------------------------
 * Non-intrusive banner that suggests a language switch based on browser preferences.
 *
 * IMPORTANT: This is a UI suggestion only — NOT an automatic redirect.
 * Auto-redirects break Google's ability to crawl all language versions.
 *
 * SSR FOOTPRINT: zero. The server only emits an empty mount node + a
 * <script type="application/json"> config blob. The full banner DOM is
 * built on the client by JS. This prevents Google from indexing
 * placeholder strings like "___" or empty href="#" links.
 *
 * Place this once in BaseLayout.astro (NOT on every page).
 */

import { useTranslations, getLangFromUrl, type Language } from '@/i18n/utils';
import { LANGUAGE_NAMES } from '@/i18n/slugs';

const currentLang: Language = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Build the i18n config once on the server. Client uses it to populate the
// banner with the suggested language's native name + flag.
// {language} is replaced on client after detecting browser preference.
const bannerConfig = {
  currentLang,
  currentPath: Astro.url.pathname,
  i18n: {
    titleTpl:    t('languages.suggest_banner.title'),
    subtitleTpl: t('languages.suggest_banner.subtitle'),
    yes:         t('languages.suggest_banner.yes'),
    no:          t('languages.suggest_banner.no'),
    close:       t('common.close'),
  },
  languages: LANGUAGE_NAMES,
};
---

{/* Empty mount + config blob. JS owns rendering. */}
<div data-lang-banner-mount aria-hidden="true"></div>
<script
  type="application/json"
  data-lang-banner-config
  is:inline
  set:html={JSON.stringify(bannerConfig)}
/>

<style is:global>
  .lang-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    max-width: min(calc(100vw - 2rem), 36rem);
    background: var(--bg-secondary, #131316);
    border: 1px solid var(--border, #27272a);
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    z-index: 80;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    animation: lang-banner-in 350ms ease-out;
  }

  .lang-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }
  @media (min-width: 640px) {
    .lang-banner__inner { flex-direction: row; align-items: center; gap: 1.5rem; }
  }

  .lang-banner__content { display: flex; gap: 0.875rem; align-items: center; flex: 1; }
  .lang-banner__flag { font-size: 1.75rem; line-height: 1; flex-shrink: 0; }
  .lang-banner__text { flex: 1; min-width: 0; }
  .lang-banner__title { margin: 0; font-size: 0.9375rem; font-weight: 500; color: var(--text-primary, #f5f5f7); line-height: 1.4; }
  .lang-banner__subtitle { margin: 0.125rem 0 0; font-size: 0.8125rem; color: var(--text-muted, #71717a); line-height: 1.4; }

  .lang-banner__actions { display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0; }
  .lang-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background-color 150ms ease, border-color 150ms ease, color 150ms ease;
    white-space: nowrap;
  }
  .lang-banner__btn--primary { background-color: var(--accent, #d7ff3d); color: var(--accent-text, #0a0a0b); }
  .lang-banner__btn--primary:hover, .lang-banner__btn--primary:focus-visible { background-color: var(--accent-hover, #c5ff1f); }
  .lang-banner__btn--secondary { background: transparent; color: var(--text-secondary, #a1a1aa); border-color: var(--border, #27272a); }
  .lang-banner__btn--secondary:hover, .lang-banner__btn--secondary:focus-visible { color: var(--text-primary, #f5f5f7); border-color: var(--text-secondary, #a1a1aa); }
  .lang-banner__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: none;
    color: var(--text-muted, #71717a);
    cursor: pointer;
    border-radius: 0.375rem;
    transition: color 150ms ease, background-color 150ms ease;
  }
  .lang-banner__close:hover, .lang-banner__close:focus-visible { color: var(--text-primary, #f5f5f7); background-color: var(--bg-tertiary, #1c1c20); }
  .lang-banner__close svg { width: 1rem; height: 1rem; }
  .lang-banner__btn:focus-visible, .lang-banner__close:focus-visible { outline: 2px solid var(--accent, #d7ff3d); outline-offset: 2px; }

  @keyframes lang-banner-in {
    from { opacity: 0; transform: translate(-50%, 1rem); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lang-banner { animation: none; }
    .lang-banner__btn, .lang-banner__close { transition: none; }
  }
</style>

<script>
  import {
    suggestLanguageFromBrowser,
    getEquivalentUrl,
    type Language,
  } from '@/i18n/utils';

  const STORAGE_KEY = 'lang-banner-dismissed';
  const STORAGE_VERSION = '1';

  interface BannerConfig {
    currentLang: Language;
    currentPath: string;
    i18n: {
      titleTpl: string;
      subtitleTpl: string;
      yes: string;
      no: string;
      close: string;
    };
    languages: Record<string, { native: string; flag: string }>;
  }

  function initLanguageBanner() {
    if (document.querySelector('.lang-banner')) return; // already rendered

    const mount = document.querySelector<HTMLElement>('[data-lang-banner-mount]');
    const configEl = document.querySelector<HTMLScriptElement>('[data-lang-banner-config]');
    if (!mount || !configEl) return;

    // Already dismissed? Render nothing.
    try {
      if (localStorage.getItem(STORAGE_KEY) === STORAGE_VERSION) return;
    } catch { /* ignore */ }

    let config: BannerConfig;
    try {
      config = JSON.parse(configEl.textContent || '{}');
    } catch { return; }

    const suggested = suggestLanguageFromBrowser(config.currentLang);
    if (!suggested) return;

    const sd = config.languages[suggested];
    if (!sd) return;

    const switchHref = getEquivalentUrl(config.currentPath, suggested);
    const title    = config.i18n.titleTpl.replace('{language}', sd.native);
    const subtitle = config.i18n.subtitleTpl.replace('{language}', sd.native);

    // Build banner DOM in a detached fragment so we never insert partial state.
    const banner = document.createElement('div');
    banner.className = 'lang-banner';
    banner.setAttribute('role', 'region');
    banner.setAttribute('aria-label', 'Language suggestion');

    const inner = document.createElement('div');
    inner.className = 'lang-banner__inner';

    const content = document.createElement('div');
    content.className = 'lang-banner__content';

    const flag = document.createElement('span');
    flag.className = 'lang-banner__flag';
    flag.setAttribute('aria-hidden', 'true');
    flag.textContent = sd.flag;

    const textWrap = document.createElement('div');
    textWrap.className = 'lang-banner__text';

    const titleEl = document.createElement('p');
    titleEl.className = 'lang-banner__title';
    titleEl.textContent = title;

    const subtitleEl = document.createElement('p');
    subtitleEl.className = 'lang-banner__subtitle';
    subtitleEl.textContent = subtitle;

    textWrap.append(titleEl, subtitleEl);
    content.append(flag, textWrap);

    const actions = document.createElement('div');
    actions.className = 'lang-banner__actions';

    const switchBtn = document.createElement('a');
    switchBtn.className = 'lang-banner__btn lang-banner__btn--primary';
    switchBtn.href = switchHref;
    switchBtn.setAttribute('hreflang', suggested);
    switchBtn.setAttribute('lang', suggested);
    switchBtn.textContent = config.i18n.yes;

    const noBtn = document.createElement('button');
    noBtn.type = 'button';
    noBtn.className = 'lang-banner__btn lang-banner__btn--secondary';
    noBtn.textContent = config.i18n.no;

    const closeBtn = document.createElement('button');
    closeBtn.type = 'button';
    closeBtn.className = 'lang-banner__close';
    closeBtn.setAttribute('aria-label', config.i18n.close);
    closeBtn.innerHTML = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"/></svg>';

    actions.append(switchBtn, noBtn, closeBtn);
    inner.append(content, actions);
    banner.append(inner);
    mount.replaceWith(banner); // commit complete tree atomically

    const dismiss = () => {
      try { localStorage.setItem(STORAGE_KEY, STORAGE_VERSION); } catch {}
      banner.remove();
    };

    noBtn.addEventListener('click', dismiss);
    closeBtn.addEventListener('click', dismiss);
    switchBtn.addEventListener('click', () => {
      try { localStorage.setItem(STORAGE_KEY, STORAGE_VERSION); } catch {}
    });
  }

  initLanguageBanner();
  document.addEventListener('astro:after-swap', initLanguageBanner);
</script>
