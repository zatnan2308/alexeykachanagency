---
/**
 * CustomCursor — premium cursor for non-touch pointers.
 * - Outer ring (32px) follows cursor with smooth lag (GSAP).
 * - Inner dot (4px) tracks pointer 1:1.
 * - Outer ring grows to ~64px when hovering buttons, links, [data-magnetic] elements.
 * - Hidden on touch devices (no `(hover: hover)` & `(pointer: fine)`).
 * - Hidden when prefers-reduced-motion.
 */
---

<div class="cursor" data-cursor aria-hidden="true">
  <span class="cursor__ring" data-cursor-ring></span>
  <span class="cursor__dot" data-cursor-dot></span>
</div>

<style>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: var(--z-tooltip);
    /* Hidden by default; activated by .js html on capable devices */
    display: none;
  }
  /* Only enable on hover-capable, fine-pointer devices */
  @media (hover: hover) and (pointer: fine) {
    .js .cursor { display: block; }
    /* Hide native cursor on interactive elements when custom cursor is on */
    .js body { cursor: none; }
    .js a,
    .js button,
    .js [role='button'],
    .js [data-magnetic],
    .js input,
    .js textarea,
    .js select,
    .js summary { cursor: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .js .cursor { display: none; }
    .js body { cursor: auto; }
    .js a, .js button { cursor: pointer; }
    .js input, .js textarea, .js select { cursor: text; }
  }

  .cursor__ring {
    position: absolute;
    top: -16px;
    left: -16px;
    width: 32px;
    height: 32px;
    border: 1px solid color-mix(in oklch, var(--accent) 65%, transparent);
    border-radius: 50%;
    transform-origin: center;
    transition: width var(--duration-base) var(--ease-out),
                height var(--duration-base) var(--ease-out),
                top var(--duration-base) var(--ease-out),
                left var(--duration-base) var(--ease-out),
                background-color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
    will-change: transform;
  }
  .cursor[data-state='active'] .cursor__ring {
    width: 56px;
    height: 56px;
    top: -28px;
    left: -28px;
    background: color-mix(in oklch, var(--accent) 14%, transparent);
    border-color: var(--accent);
  }
  .cursor[data-state='click'] .cursor__ring {
    width: 24px;
    height: 24px;
    top: -12px;
    left: -12px;
  }

  .cursor__dot {
    position: absolute;
    top: -2px;
    left: -2px;
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    will-change: transform;
  }
</style>
