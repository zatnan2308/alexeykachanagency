---
/**
 * IntroLoader — subtle 1.0–1.5s loader on first visit per session.
 * Fades out automatically (animations.ts handles the GSAP timeline).
 * Skipped on prefers-reduced-motion or repeat visits.
 *
 * Render at the very start of <body> so it covers everything before paint.
 */
---

<div class="intro" data-intro-loader aria-hidden="true">
  <div class="intro__inner">
    <p class="intro__text" data-intro-text>
      <span class="intro__brand">Alexey Kachan</span><span class="intro__dot">.</span>
    </p>
    <span class="intro__bar-wrap" aria-hidden="true">
      <span class="intro__bar" data-intro-bar></span>
    </span>
  </div>
</div>

<style>
  .intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  /* If JS is disabled, hide entirely (no fade-out would happen). */
  .no-js .intro { display: none; }
  /* prefers-reduced-motion: hide immediately. */
  @media (prefers-reduced-motion: reduce) {
    .intro { display: none; }
  }

  .intro__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: min(80vw, 22rem);
  }
  .intro__text {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1rem + 1vw, 1.625rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .intro__dot { color: var(--accent); }
  .intro__bar-wrap {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--border);
    overflow: hidden;
  }
  .intro__bar {
    display: block;
    width: 0%;
    height: 100%;
    background: var(--accent);
  }
</style>
