---
import { useTranslations, getLocalizedPath, type Language } from '@/i18n/utils';

interface Props { lang: Language }
const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  { key: 'website_development',     pageKey: 'services.website-development',     num: '01' },
  { key: 'mobile_app_development',  pageKey: 'services.mobile-app-development',  num: '02' },
  { key: 'site_design',             pageKey: 'services.site-design',             num: '03' },
  { key: 'site_redesign',           pageKey: 'services.site-redesign',           num: '04' },
  { key: 'site_analytics',          pageKey: 'services.site-analytics',          num: '05' },
  { key: 'setting_up_ads',          pageKey: 'services.setting-up-ads',          num: '06' },
  { key: 'site_support',            pageKey: 'services.site-support',            num: '07' },
] as const;
---

<section class="services section-y" id="services">
  <div class="container-x">
    <header class="services__header" data-reveal>
      <p class="services__label">— {t('services_section.label')}</p>
      <h2 class="services__title text-balance">{t('services_section.title')}</h2>
      <p class="services__subtitle">{t('services_section.subtitle')}</p>
    </header>

    <ul class="services__grid" data-reveal-stagger data-stagger-interval="0.06">
      {services.map((s) => (
        <li class="services__card">
          <a href={getLocalizedPath(s.pageKey, lang)} class="services__card-link">
            <span class="services__num">{s.num}</span>
            <h3 class="services__card-title">{t(`services_section.items.${s.key}.title`)}</h3>
            <p class="services__card-text">{t(`services_section.items.${s.key}.short`)}</p>
            <span class="services__arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="services__cta">
      <a href={getLocalizedPath('services', lang)} class="services__cta-link">
        {t('common.view_all')} {t('nav.services').toLowerCase()}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .services__header {
    max-width: 48rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .services__label {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }
  .services__title {
    font-size: var(--text-5xl);
    margin-bottom: 1rem;
  }
  .services__subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 640px) {
    .services__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .services__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .services__card {
    background: var(--bg-primary);
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .services__card:hover {
    background: var(--bg-secondary);
  }

  .services__card-link {
    display: grid;
    grid-template-rows: auto 1fr auto;
    grid-template-columns: 1fr auto;
    gap: 0.75rem 1rem;
    padding: 2rem;
    height: 100%;
    min-height: 16rem;
  }

  .services__num {
    grid-column: 1;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    align-self: start;
  }

  .services__card-title {
    grid-column: 1 / -1;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.3rem + 0.6vw, 1.875rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    align-self: end;
  }
  .services__card-text {
    grid-column: 1;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
    align-self: end;
  }
  .services__arrow {
    grid-column: 2;
    grid-row: 3;
    align-self: end;
    color: var(--text-muted);
    transition: color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .services__card:hover .services__arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .services__cta {
    margin-top: 2.5rem;
    text-align: center;
  }
  .services__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-full);
    color: var(--text-primary);
    font-weight: 500;
    transition: background-color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }
  .services__cta-link:hover {
    background: var(--bg-secondary);
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
