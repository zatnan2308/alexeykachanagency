---
import { useTranslations, getTranslations, type Language } from '@/i18n/utils';

interface Props { lang: Language }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Get items array directly (not via dot-notation since useTranslations returns string only)
const all = getTranslations(lang) as any;
const items: Array<{ quote: string; author: string; role: string; country: string }> =
  all?.testimonials?.items ?? (getTranslations('en') as any).testimonials.items;
---

<section class="quotes section-y">
  <div class="container-x">
    <header class="quotes__header" data-reveal>
      <p class="quotes__label">— {t('testimonials.label')}</p>
      <h2 class="quotes__title text-balance">{t('testimonials.title')}</h2>
    </header>

    <ul class="quotes__grid" data-reveal-stagger data-stagger-interval="0.12">
      {items.map((q) => (
        <li class="quotes__item">
          <svg class="quotes__mark" width="32" height="24" viewBox="0 0 32 24" fill="none" aria-hidden="true">
            <path d="M0 24V14C0 9.6 1.067 6.067 3.2 3.4C5.333 0.733 8.4 -0.4 12.4 0L13 4.4C10.6 4.667 8.733 5.6 7.4 7.2C6.067 8.8 5.4 10.933 5.4 13.6H12V24H0ZM18 24V14C18 9.6 19.067 6.067 21.2 3.4C23.333 0.733 26.4 -0.4 30.4 0L31 4.4C28.6 4.667 26.733 5.6 25.4 7.2C24.067 8.8 23.4 10.933 23.4 13.6H30V24H18Z" fill="currentColor"/>
          </svg>
          <blockquote class="quotes__text">{q.quote}</blockquote>
          <footer class="quotes__author">
            <p class="quotes__name">{q.author}</p>
            <p class="quotes__role">{q.role} · {q.country}</p>
            <p class="quotes__verified">{t('testimonials.verified_badge')}</p>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .quotes__header {
    max-width: 48rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .quotes__label {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .quotes__title {
    font-size: var(--text-5xl);
  }

  .quotes__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) {
    .quotes__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .quotes__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .quotes__item {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .quotes__mark {
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .quotes__text {
    flex: 1;
    margin: 0 0 1.5rem;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text-primary);
    font-style: normal;
  }
  .quotes__author {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
  }
  .quotes__name {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.125rem;
  }
  .quotes__role {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .quotes__verified {
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
</style>
