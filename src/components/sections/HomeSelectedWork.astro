---
import { useTranslations, getLocalizedPath, type Language } from '@/i18n/utils';

interface Props { lang: Language }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Placeholder cases — replace with content collection later.
const cases = [
  {
    slug: 'bauer-manufaktur',
    title: 'Bauer Manufaktur',
    tagline: 'B2B manufacturer site rebuild',
    metric: '+186% organic traffic',
    services: ['Web Development', 'SEO'],
    accent: '#d7ff3d',
  },
  {
    slug: 'olea-studio',
    title: 'Olea Studio',
    tagline: 'Lead-gen overhaul for boutique studio',
    metric: '−38% CPA, 2.4× leads',
    services: ['Paid Ads', 'Web Design'],
    accent: '#a3e635',
  },
  {
    slug: 'northwind-ltd',
    title: 'Northwind Ltd',
    tagline: 'Multilingual platform for 6 markets',
    metric: '8 languages · 4× speed',
    services: ['Development', 'Localization'],
    accent: '#f59e0b',
  },
  {
    slug: 'helios-capital',
    title: 'Helios Capital',
    tagline: 'Investor portal redesign',
    metric: 'CWV 95+ across all pages',
    services: ['Redesign', 'Performance'],
    accent: '#60a5fa',
  },
];
---

<section class="work section-y">
  <div class="container-x">
    <header class="work__header" data-reveal>
      <div>
        <p class="work__label">— {t('selected_work.label')}</p>
        <h2 class="work__title text-balance">{t('selected_work.title')}</h2>
      </div>
      <p class="work__sub">{t('selected_work.subtitle')}</p>
    </header>

    <ul class="work__grid" data-reveal-stagger data-stagger-interval="0.1">
      {cases.map((c) => (
        <li class="work__item">
          <a href={getLocalizedPath('cases.web-development', lang)} class="work__link">
            <div class="work__media" style={`--case-accent: ${c.accent}`}>
              <span class="work__metric">{c.metric}</span>
              <span class="work__brand">{c.title}</span>
            </div>
            <div class="work__meta">
              <h3 class="work__heading">{c.tagline}</h3>
              <ul class="work__tags">
                {c.services.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="work__cta">
      <a href={getLocalizedPath('cases.web-development', lang)} class="work__cta-link" data-magnetic data-magnetic-strength="0.3">
        {t('selected_work.view_all')}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .work__header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  @media (min-width: 768px) {
    .work__header {
      grid-template-columns: 2fr 1fr;
      align-items: end;
      gap: 3rem;
    }
  }
  .work__label {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .work__title {
    font-size: var(--text-5xl);
    max-width: 32rem;
  }
  .work__sub {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.5;
  }

  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) {
    .work__grid { grid-template-columns: 1fr 1fr; }
  }

  .work__item {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    transition: border-color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .work__item:hover {
    border-color: var(--border-strong);
    transform: translateY(-4px);
  }

  .work__link {
    display: block;
    color: inherit;
  }

  .work__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background:
      linear-gradient(135deg, var(--bg-tertiary) 0%, var(--bg-elevated) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 1.75rem;
    overflow: hidden;
  }
  .work__media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 100%, color-mix(in oklch, var(--case-accent, var(--accent)) 18%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }
  .work__metric {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--case-accent, var(--accent));
    background: color-mix(in oklch, var(--bg-primary) 60%, transparent);
    backdrop-filter: blur(8px);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in oklch, var(--case-accent, var(--accent)) 30%, transparent);
  }
  .work__brand {
    position: relative;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .work__meta {
    padding: 1.5rem 1.75rem 1.75rem;
  }
  .work__heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.875rem;
    line-height: 1.25;
  }
  .work__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .work__tags li {
    font-size: 0.75rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg-tertiary);
    color: var(--text-muted);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
  }

  .work__cta {
    margin-top: 3rem;
    text-align: center;
  }
  .work__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--accent);
    color: var(--accent-text);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: background-color var(--duration-fast) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .work__cta-link:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }
</style>
