---
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath, type Language } from '@/i18n/utils';
import { slugs } from '@/i18n/slugs';

interface Props { lang: Language }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Pull all web-development cases, group by slug, pick best language match
const allCases = await getCollection('cases', ({ data }) => !data.draft && data.category === 'web-development');

const bySlug = new Map<string, typeof allCases>();
for (const c of allCases) {
  const [s] = c.id.split('/');
  if (!bySlug.has(s)) bySlug.set(s, []);
  bySlug.get(s)!.push(c);
}

// Sort: featured first, then most recent. Take up to 4.
const cases = Array.from(bySlug.entries())
  .map(([slug, variants]) => {
    const match =
      variants.find((v) => v.data.lang === lang) ??
      variants.find((v) => v.data.lang === 'en') ??
      variants[0];
    return { slug, post: match };
  })
  .sort((a, b) => {
    const af = a.post.data.featured ? 1 : 0;
    const bf = b.post.data.featured ? 1 : 0;
    if (af !== bf) return bf - af;
    return +new Date(b.post.data.published) - +new Date(a.post.data.published);
  })
  .slice(0, 4);

// Build per-case detail URL
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const detailPrefix = slugs['cases.detail.prefix']?.[lang] ?? 'cases';
const caseHref = (caseSlug: string) => `${langPrefix}/${detailPrefix}/${caseSlug}/`;
---

<section class="work section-y">
  <div class="container-x">
    <header class="work__header" data-reveal>
      <div>
        <p class="work__label">— {t('selected_work.label')}</p>
        <h2 class="work__title text-balance">{t('selected_work.title')}</h2>
      </div>
      <p class="work__sub">{t('selected_work.subtitle')}</p>
    </header>

    {cases.length > 0 && (
      <ul class="work__grid" data-reveal-stagger data-stagger-interval="0.1">
        {cases.map(({ slug, post }) => (
          <li class="work__item">
            <a href={caseHref(slug)} class="work__link">
              <div class="work__media" style={`--case-accent: ${post.data.accent}`}>
                <img
                  src={`/cases/${slug}/cover.jpg`}
                  alt={`${post.data.client} — website screenshot`}
                  class="work__cover"
                  loading="lazy"
                  decoding="async"
                />
                <span class="work__metric">{post.data.heroMetric}</span>
                <span class="work__brand">{post.data.client}</span>
              </div>
              <div class="work__meta">
                <h3 class="work__heading">{post.data.title}</h3>
                <ul class="work__tags">
                  {post.data.services.map((s: string) => <li>{s}</li>)}
                </ul>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}

    <div class="work__cta">
      <a href={getLocalizedPath('cases.web-development', lang)} class="work__cta-link" data-magnetic data-magnetic-strength="0.3">
        {t('selected_work.view_all')}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .work__header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  @media (min-width: 768px) {
    .work__header {
      grid-template-columns: 2fr 1fr;
      align-items: end;
      gap: 3rem;
    }
  }
  .work__label {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .work__title {
    font-size: var(--text-5xl);
    max-width: 32rem;
  }
  .work__sub {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.5;
  }

  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) {
    .work__grid { grid-template-columns: 1fr 1fr; }
  }

  .work__item {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    transition: border-color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .work__item:hover {
    border-color: var(--border-strong);
    transform: translateY(-4px);
  }

  .work__link {
    display: block;
    color: inherit;
  }

  .work__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background:
      linear-gradient(135deg, var(--bg-tertiary) 0%, var(--bg-elevated) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 1.75rem;
    overflow: hidden;
  }
  .work__cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .work__item:hover .work__cover { transform: scale(1.04); }
  .work__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, color-mix(in oklch, var(--bg-primary) 85%, transparent) 100%);
    pointer-events: none;
  }
  .work__media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 100%, color-mix(in oklch, var(--case-accent, var(--accent)) 18%, transparent) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }
  .work__metric {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--case-accent, var(--accent));
    background: color-mix(in oklch, var(--bg-primary) 70%, transparent);
    backdrop-filter: blur(8px);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in oklch, var(--case-accent, var(--accent)) 30%, transparent);
    max-width: calc(100% - 2rem);
  }
  .work__brand {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    text-shadow: 0 2px 12px color-mix(in oklch, var(--bg-primary) 80%, transparent);
  }

  .work__meta {
    padding: 1.5rem 1.75rem 1.75rem;
  }
  .work__heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.875rem;
    line-height: 1.25;
  }
  .work__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .work__tags li {
    font-size: 0.75rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg-tertiary);
    color: var(--text-muted);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
  }

  .work__cta {
    margin-top: 3rem;
    text-align: center;
  }
  .work__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--accent);
    color: var(--accent-text);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: background-color var(--duration-fast) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .work__cta-link:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }
</style>
