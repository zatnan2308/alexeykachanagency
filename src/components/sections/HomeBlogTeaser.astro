---
import { useTranslations, getLocalizedPath, formatDate, type Language } from '@/i18n/utils';

interface Props { lang: Language }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Placeholder posts — replace with content collection later.
const posts = [
  {
    slug: 'core-web-vitals-2026',
    title: 'Core Web Vitals in 2026: what actually moves rankings',
    excerpt: 'INP replaced FID and changed everything. Here is what to optimize first if you have one engineering day.',
    date: '2026-04-12',
    minutes: 6,
  },
  {
    slug: 'multilingual-seo-without-pain',
    title: 'Multilingual SEO without the migration headache',
    excerpt: 'Subdirectories vs subdomains, hreflang reality check, and why machine translation kills your rankings.',
    date: '2026-03-28',
    minutes: 9,
  },
  {
    slug: 'google-ads-budget-audit',
    title: 'A 30-minute audit that cuts Google Ads waste by 25%',
    excerpt: 'Six checks every account fails. Run them this afternoon before you renew next month\u2019s budget.',
    date: '2026-03-10',
    minutes: 5,
  },
];
---

<section class="blog section-y">
  <div class="container-x">
    <header class="blog__header" data-reveal>
      <div>
        <p class="blog__label">— {t('blog_teaser.label')}</p>
        <h2 class="blog__title text-balance">{t('blog_teaser.title')}</h2>
      </div>
      <a href={getLocalizedPath('blog', lang)} class="blog__view-all">
        {t('blog_teaser.view_all')}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </header>

    <ul class="blog__grid" data-reveal-stagger data-stagger-interval="0.1">
      {posts.map((p) => (
        <li class="blog__item">
          <a href={getLocalizedPath('blog', lang)} class="blog__link">
            <p class="blog__meta">
              <time datetime={p.date}>{formatDate(p.date, lang)}</time>
              <span aria-hidden="true">·</span>
              <span>{p.minutes} {t('common.min_read')}</span>
            </p>
            <h3 class="blog__heading">{p.title}</h3>
            <p class="blog__excerpt">{p.excerpt}</p>
            <span class="blog__more">
              {t('common.read_more')}
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .blog__header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  @media (min-width: 768px) {
    .blog__header {
      flex-direction: row;
      align-items: end;
      justify-content: space-between;
    }
  }
  .blog__label {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .blog__title {
    font-size: var(--text-5xl);
  }
  .blog__view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    font-weight: 500;
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: 0.25rem;
    transition: color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }
  .blog__view-all:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) {
    .blog__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .blog__item {
    background: var(--bg-primary);
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .blog__item:hover {
    background: var(--bg-secondary);
  }

  .blog__link {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 2rem;
    height: 100%;
    color: inherit;
  }
  .blog__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
  .blog__heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
    letter-spacing: -0.015em;
  }
  .blog__excerpt {
    flex: 1;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .blog__more {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: 0.5rem;
    transition: gap var(--duration-base) var(--ease-out);
  }
  .blog__item:hover .blog__more {
    gap: 0.625rem;
  }
</style>
