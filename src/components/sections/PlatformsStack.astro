---
/**
 * PlatformsStack — platforms & stack section, used on website-development service page.
 * Renders 4 groups of platforms (Quick & affordable / Most popular / Performance / Custom).
 * Mobile-first: each group is a card grid; on desktop, groups stack vertically with
 * platforms displayed as 1–3 cards side by side per group.
 *
 * Data shape (from translations):
 *   {
 *     label, title, subtitle, cta_helper,
 *     groups: [
 *       { id, title, subtitle, platforms: [{ name, when, price, accent? }] }
 *     ]
 *   }
 */

interface Platform {
  name: string;
  when: string;
  price: string;
}
interface Group {
  id: string;
  title: string;
  subtitle: string;
  platforms: Platform[];
}
interface Props {
  data: {
    label: string;
    title: string;
    subtitle: string;
    cta_helper: string;
    groups: Group[];
  };
}
const { data } = Astro.props;
---

<section class="svc-platforms section-y">
  <div class="container-x">
    <header class="svc-platforms__head" data-reveal>
      <p class="svc-platforms__label">— {data.label}</p>
      <h2 class="svc-platforms__title text-balance">{data.title}</h2>
      <p class="svc-platforms__sub">{data.subtitle}</p>
    </header>

    <div class="svc-platforms__groups" data-reveal-stagger data-stagger-interval="0.08">
      {data.groups.map((group) => (
        <article class="svc-platforms__group" data-group-id={group.id}>
          <header class="svc-platforms__group-head">
            <h3 class="svc-platforms__group-title">{group.title}</h3>
            <p class="svc-platforms__group-sub">{group.subtitle}</p>
          </header>

          <ul class="svc-platforms__cards">
            {group.platforms.map((p) => (
              <li class="svc-platforms__card">
                <h4 class="svc-platforms__name">{p.name}</h4>
                <p class="svc-platforms__when">{p.when}</p>
                <span class="svc-platforms__price">{p.price}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <p class="svc-platforms__helper" data-reveal>{data.cta_helper}</p>
  </div>
</section>

<style>
  .svc-platforms {
    background: var(--bg-secondary);
    border-block: 1px solid var(--border);
  }

  .svc-platforms__head {
    max-width: 48rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .svc-platforms__label {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .svc-platforms__title {
    font-size: var(--text-5xl);
    margin-bottom: 1rem;
  }
  .svc-platforms__sub {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.55;
  }

  .svc-platforms__groups {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .svc-platforms__group {
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    background: var(--bg-primary);
  }
  @media (min-width: 768px) {
    .svc-platforms__group { padding: 2.25rem; }
  }

  .svc-platforms__group-head {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .svc-platforms__group-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.1rem + 0.4vw, 1.5rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.015em;
    margin-bottom: 0.5rem;
  }
  .svc-platforms__group-sub {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .svc-platforms__cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .svc-platforms__cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .svc-platforms__cards { grid-template-columns: repeat(3, 1fr); }
  }

  .svc-platforms__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.25rem 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition:
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }
  .svc-platforms__card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .svc-platforms__name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .svc-platforms__when {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0 0 0.5rem;
    flex: 1;
  }
  .svc-platforms__price {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .svc-platforms__helper {
    margin-top: clamp(2rem, 4vw, 3rem);
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.55;
    text-align: center;
    max-width: 44rem;
    margin-left: auto;
    margin-right: auto;
  }
</style>
