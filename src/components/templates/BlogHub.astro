---
/**
 * BlogHub — /blog/ landing page.
 * Lists all blog posts available in the current language (with EN fallback for missing translations).
 */
import { getCollection } from 'astro:content';
import { useTranslations, getTranslations, formatDate, formatReadingTime, type Language } from '@/i18n/utils';
import { slugs } from '@/i18n/slugs';
import Breadcrumb from '@/components/layout/Breadcrumb.astro';

interface Props { lang: Language }
const { lang } = Astro.props;
const t = useTranslations(lang);
const all = getTranslations(lang) as any;
const enAll = getTranslations('en') as any;
const hub = all?.blog_pages?.hub ?? enAll.blog_pages.hub;

// Pull every blog entry — non-draft only
const allPosts = (await getCollection('blog', ({ data }) => !data.draft));

// Group by post slug (folder name) — pick best language match: requested lang → en → first available
const bySlug = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  // post.id is "<slug>/<lang>" (folder loader includes path)
  const [slug] = post.id.split('/');
  if (!bySlug.has(slug)) bySlug.set(slug, []);
  bySlug.get(slug)!.push(post);
}

const posts = Array.from(bySlug.entries())
  .map(([slug, variants]) => {
    const match =
      variants.find((v) => v.data.lang === lang) ??
      variants.find((v) => v.data.lang === 'en') ??
      variants[0];
    return { slug, post: match, isFallback: match.data.lang !== lang };
  })
  .sort((a, b) => +new Date(b.post.data.published) - +new Date(a.post.data.published));

// Build blog post URL: localized blog hub path + post slug
const postHref = (postSlug: string) => {
  const hubPath = slugs.blog?.[lang] ?? 'blog';
  const langPrefix = lang === 'en' ? '' : `/${lang}`;
  return `${langPrefix}/${hubPath}/${postSlug}/`;
};

// Collect unique tags
const allTags = Array.from(new Set(posts.flatMap((p) => p.post.data.tags))).sort();

// Featured + rest
const featured = posts.find((p) => p.post.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.slug !== featured?.slug);
---

<Breadcrumb lang={lang} items={[{ name: t('page_titles.blog') }]} visualHidden={true} />

<section class="blog-hub-hero">
  <div class="container-x blog-hub-hero__inner">
    <p class="blog-hub-hero__kicker" data-reveal>— {hub.kicker}</p>
    <h1 class="blog-hub-hero__h1 text-balance" data-reveal data-reveal-delay="0.1">{hub.h1}</h1>
    <p class="blog-hub-hero__lead" data-reveal data-reveal-delay="0.2">{hub.lead}</p>
  </div>
</section>

{featured && (
  <section class="blog-hub-featured section-y-sm">
    <div class="container-x">
      <a href={postHref(featured.slug)} class="blog-hub-featured__card" data-reveal>
        <span class="blog-hub-featured__badge">{hub.featured_label}</span>
        <p class="blog-hub-featured__meta">
          <time datetime={featured.post.data.published.toISOString()}>{formatDate(featured.post.data.published, lang)}</time>
          <span aria-hidden="true">·</span>
          <span>{formatReadingTime(featured.post.body ?? '', lang)}</span>
        </p>
        <h2 class="blog-hub-featured__title text-balance">{featured.post.data.title}</h2>
        <p class="blog-hub-featured__desc">{featured.post.data.description}</p>
        <span class="blog-hub-featured__cta">
          {t('common.read_more')}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
  </section>
)}

<section class="blog-hub-list section-y">
  <div class="container-x">
    {allTags.length > 0 && (
      <nav class="blog-hub-filters" aria-label="Filter by tag" data-reveal>
        <button type="button" class="blog-hub-filter is-active" data-tag="all">{hub.filter_all}</button>
        {allTags.map((tag) => (
          <button type="button" class="blog-hub-filter" data-tag={tag}>{tag}</button>
        ))}
      </nav>
    )}

    {rest.length > 0 ? (
      <ul class="blog-hub-grid" data-reveal-stagger data-stagger-interval="0.08">
        {rest.map(({ slug, post, isFallback }) => (
          <li class="blog-hub-item" data-tags={post.data.tags.join(',')}>
            <a href={postHref(slug)} class="blog-hub-card">
              <p class="blog-hub-card__meta">
                <time datetime={post.data.published.toISOString()}>{formatDate(post.data.published, lang)}</time>
                <span aria-hidden="true">·</span>
                <span>{formatReadingTime(post.body ?? '', lang)}</span>
              </p>
              <h3 class="blog-hub-card__title">{post.data.title}</h3>
              <p class="blog-hub-card__desc">{post.data.description}</p>
              <ul class="blog-hub-card__tags">
                {post.data.tags.map((tag: string) => <li>{tag}</li>)}
              </ul>
              {isFallback && <span class="blog-hub-card__fallback">EN</span>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="blog-hub-empty">{hub.no_results}</p>
    )}
  </div>
</section>

<style>
  .blog-hub-hero {
    padding-top: calc(var(--header-height) + clamp(3rem, 8vw, 6rem));
    padding-bottom: clamp(2rem, 4vw, 4rem);
  }
  .blog-hub-hero__inner { max-width: 56rem; }
  .blog-hub-hero__kicker { font-size: 0.875rem; color: var(--accent); font-weight: 500; margin-bottom: 1.5rem; }
  .blog-hub-hero__h1 {
    font-family: var(--font-display);
    font-size: var(--text-6xl);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-bottom: 1.25rem;
  }
  .blog-hub-hero__lead {
    font-size: clamp(1.125rem, 0.95rem + 0.7vw, 1.375rem);
    color: var(--text-secondary);
    line-height: 1.5;
    max-width: 44rem;
  }

  /* Featured */
  .blog-hub-featured__card {
    display: block;
    position: relative;
    padding: clamp(2rem, 4vw, 3rem);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    color: inherit;
    transition: border-color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
    overflow: hidden;
  }
  .blog-hub-featured__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 100% 0%, color-mix(in oklch, var(--accent) 12%, transparent), transparent 60%);
    pointer-events: none;
  }
  .blog-hub-featured__card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .blog-hub-featured__badge {
    position: relative;
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: var(--accent);
    color: var(--accent-text);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: var(--radius-full);
    margin-bottom: 1rem;
  }
  .blog-hub-featured__meta {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .blog-hub-featured__title {
    position: relative;
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 1.4rem + 1.7vw, 2.75rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 1rem;
    max-width: 36rem;
  }
  .blog-hub-featured__desc {
    position: relative;
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.55;
    max-width: 42rem;
    margin-bottom: 1.5rem;
  }
  .blog-hub-featured__cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    font-weight: 600;
    transition: gap var(--duration-base) var(--ease-out);
  }
  .blog-hub-featured__card:hover .blog-hub-featured__cta { gap: 0.75rem; }

  /* Filters */
  .blog-hub-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .blog-hub-filter {
    padding: 0.5rem 0.875rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }
  .blog-hub-filter:hover { color: var(--text-primary); border-color: var(--text-secondary); }
  .blog-hub-filter.is-active {
    background: var(--accent);
    color: var(--accent-text);
    border-color: var(--accent);
  }

  /* Grid */
  .blog-hub-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 768px) { .blog-hub-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .blog-hub-grid { grid-template-columns: repeat(3, 1fr); } }
  .blog-hub-item { background: var(--bg-primary); transition: background-color var(--duration-base) var(--ease-out); }
  .blog-hub-item:hover { background: var(--bg-secondary); }
  .blog-hub-item[hidden] { display: none; }

  .blog-hub-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    height: 100%;
    color: inherit;
    position: relative;
  }
  .blog-hub-card__meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
  }
  .blog-hub-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .blog-hub-card__desc {
    flex: 1;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .blog-hub-card__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }
  .blog-hub-card__tags li {
    font-size: 0.6875rem;
    padding: 0.2rem 0.5rem;
    background: var(--bg-tertiary);
    color: var(--text-muted);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
  }
  .blog-hub-card__fallback {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    padding: 0.125rem 0.5rem;
    background: var(--bg-tertiary);
    color: var(--text-muted);
    border-radius: var(--radius-full);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .blog-hub-empty {
    text-align: center;
    color: var(--text-muted);
    padding: 4rem 0;
    font-style: italic;
  }
</style>

<script>
  // Tag filter — shows/hides cards by data-tags attribute
  function initBlogFilters() {
    const filters = document.querySelectorAll<HTMLButtonElement>('.blog-hub-filter');
    const items = document.querySelectorAll<HTMLElement>('.blog-hub-item');
    if (!filters.length || !items.length) return;

    filters.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        filters.forEach((b) => b.classList.toggle('is-active', b === btn));
        const tag = btn.dataset.tag || 'all';
        items.forEach((item) => {
          const tags = (item.dataset.tags || '').split(',');
          item.hidden = !(tag === 'all' || tags.includes(tag));
        });
      });
    });
  }
  initBlogFilters();
  document.addEventListener('astro:page-load', initBlogFilters);
</script>
