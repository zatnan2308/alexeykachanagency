---
/**
 * BriefForm — comprehensive intake brief, accordion sections.
 * Variants: 'website' | 'ads'
 *
 * Field schema lives in translations under
 *   brief_pages.<variant>.contact_fields  — quick-contact inputs (top of form)
 *   brief_pages.<variant>.sections        — array of { title, subtitle, name, placeholder }
 *
 * Each section is rendered as a single textarea so the user can answer
 * the listed sub-questions in their own words. Mobile-friendly: each
 * accordion fits one screen, can be opened/closed without losing entered text.
 *
 * Submission goes to Web3Forms with redirect to localized thank-you page.
 */
import { useTranslations, getTranslations, getLocalizedPath, type Language } from '@/i18n/utils';
import Breadcrumb from '@/components/layout/Breadcrumb.astro';

const WEB3FORMS_KEY = (import.meta.env.PUBLIC_WEB3FORMS_KEY as string | undefined) || 'REPLACE_WITH_WEB3FORMS_KEY';

interface Props {
  lang: Language;
  variant: 'website' | 'ads';
}
const { lang, variant } = Astro.props;
const t = useTranslations(lang);
const all = getTranslations(lang) as any;
const enAll = getTranslations('en') as any;
const data = all?.brief_pages?.[variant] ?? enAll.brief_pages[variant];
const common = all?.brief_pages?.common ?? enAll.brief_pages.common;

const thankYouUrl = getLocalizedPath('thank-you', lang) || '/thank-you/';

interface ContactField {
  name: string;
  label: string;
  type: 'text' | 'email' | 'tel' | 'url';
  required?: boolean;
  placeholder?: string;
}
interface Section {
  title: string;
  subtitle?: string;
  name: string;
  placeholder?: string;
}

const contactFields: ContactField[] = data.contact_fields ?? enAll.brief_pages[variant].contact_fields;
const sections: Section[] = data.sections ?? enAll.brief_pages[variant].sections;
---

<Breadcrumb
  lang={lang}
  items={[
    { name: t('page_titles.contacts'), pageKey: 'contacts' },
    { name: variant === 'website' ? t('page_titles.brief_website') : t('page_titles.brief_ads') },
  ]}
  visualHidden={true}
/>

<section class="brief-hero">
  <div class="container-x brief-hero__inner">
    <p class="brief-hero__kicker" data-reveal>— {data.kicker}</p>
    <h1 class="brief-hero__h1 text-balance" data-reveal data-reveal-delay="0.1">{data.h1}</h1>
    <p class="brief-hero__lead" data-reveal data-reveal-delay="0.2">{data.lead}</p>
    <p class="brief-hero__note" data-reveal data-reveal-delay="0.3">{common.intro_note}</p>
  </div>
</section>

<section class="brief-body section-y-sm">
  <div class="container-x">
    <form
      class="brief-form"
      data-brief-form
      data-brief-variant={variant}
      action="https://api.web3forms.com/submit"
      method="POST"
      novalidate
      data-reveal
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value={`alexeykachan.com — ${variant} brief`} />
      <input type="hidden" name="from_name" value={`alexeykachan.com — ${variant} brief`} />
      <input type="hidden" name="redirect" value={thankYouUrl} />
      <input type="checkbox" name="botcheck" class="brief-form__honeypot" tabindex="-1" autocomplete="off" />

      {/* Quick contact group — always visible */}
      <fieldset class="brief-form__group brief-form__group--contact">
        <legend class="brief-form__legend">
          <span class="brief-form__legend-num">/01</span>
          <span>{common.contact_section_title}</span>
        </legend>
        <div class="brief-form__fields">
          {contactFields.map((f) => (
            <label class={`brief-form__field ${f.type === 'tel' ? '' : 'is-half'}`}>
              <span class="brief-form__label">
                {f.label}
                {f.required ? <em>{common.required_label}</em> : <em>{common.optional_label}</em>}
              </span>
              <input
                type={f.type}
                name={f.name}
                required={f.required}
                placeholder={f.placeholder ?? ''}
                class="brief-form__input"
                autocomplete={f.type === 'email' ? 'email' : f.type === 'tel' ? 'tel' : 'on'}
              />
            </label>
          ))}
        </div>
      </fieldset>

      {/* Section accordions — one textarea per section with sub-question hints */}
      {sections.map((s, i) => {
        const num = (i + 2).toString().padStart(2, '0');
        const isOpen = i < 2; // first 2 sections open by default; rest closed
        return (
          <details class="brief-form__group brief-form__group--section" open={isOpen}>
            <summary class="brief-form__legend">
              <span class="brief-form__legend-num">/{num}</span>
              <span>{s.title}</span>
              <svg class="brief-form__chevron" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="brief-form__section-body">
              {s.subtitle && <p class="brief-form__section-sub">{s.subtitle}</p>}
              <textarea
                name={s.name}
                rows="6"
                class="brief-form__textarea"
                placeholder={s.placeholder ?? ''}
              />
            </div>
          </details>
        );
      })}

      <label class="brief-form__consent">
        <input type="checkbox" name="consent" required />
        <span>{t('form.consent')}</span>
      </label>

      <button type="submit" class="brief-form__submit" data-magnetic data-magnetic-strength="0.3">
        <span class="brief-form__submit-label">{common.submit}</span>
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <p class="brief-form__status" data-brief-status role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  .brief-hero {
    padding-top: calc(var(--header-height) + clamp(3rem, 8vw, 6rem));
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  .brief-hero__inner { max-width: 56rem; }
  .brief-hero__kicker { font-size: 0.875rem; color: var(--accent); font-weight: 500; margin-bottom: 1.25rem; }
  .brief-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 2.5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .brief-hero__lead {
    font-size: clamp(1.0625rem, 0.95rem + 0.5vw, 1.25rem);
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 44rem;
    margin-bottom: 1.25rem;
  }
  .brief-hero__note { color: var(--text-muted); font-size: 0.875rem; max-width: 36rem; }

  .brief-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }
  .brief-form__honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; }

  .brief-form__group {
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    background: var(--bg-secondary);
    margin: 0;
  }
  @media (min-width: 768px) { .brief-form__group { padding: 2rem; } }

  .brief-form__group--section { padding: 0; transition: border-color var(--duration-fast) var(--ease-out); }
  .brief-form__group--section[open] { border-color: var(--border-strong, var(--border)); }
  .brief-form__group--section > summary { padding: 1.25rem 1.5rem; cursor: pointer; list-style: none; }
  .brief-form__group--section > summary::-webkit-details-marker { display: none; }
  @media (min-width: 768px) {
    .brief-form__group--section > summary { padding: 1.5rem 2rem; }
  }
  .brief-form__group--section > summary:hover .brief-form__legend { color: var(--text-primary); }
  .brief-form__chevron { margin-left: auto; transition: transform var(--duration-base) var(--ease-out); color: var(--text-muted); }
  .brief-form__group--section[open] .brief-form__chevron { transform: rotate(180deg); }

  .brief-form__legend {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0;
    width: 100%;
  }
  .brief-form__group--contact .brief-form__legend { margin-bottom: 1.5rem; }
  .brief-form__legend-num {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .brief-form__section-body {
    padding: 0 1.5rem 1.5rem;
  }
  @media (min-width: 768px) {
    .brief-form__section-body { padding: 0 2rem 1.75rem; }
  }
  .brief-form__section-sub {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
    margin-bottom: 1rem;
    max-width: 44rem;
  }

  .brief-form__fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .brief-form__fields { grid-template-columns: 1fr 1fr; }
  }
  .brief-form__field { display: flex; flex-direction: column; gap: 0.5rem; }
  .brief-form__field.is-half { grid-column: span 1; }
  .brief-form__label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.625rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
  }
  .brief-form__label em {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .brief-form__input,
  .brief-form__textarea {
    width: 100%;
    padding: 0.75rem 0.875rem;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    font-family: inherit;
    transition: border-color var(--duration-fast) var(--ease-out), background-color var(--duration-fast) var(--ease-out);
  }
  .brief-form__textarea {
    min-height: 8rem;
    resize: vertical;
    line-height: 1.55;
    white-space: pre-wrap;
  }
  .brief-form__textarea::placeholder { color: var(--text-muted); opacity: 0.85; }
  .brief-form__input:focus,
  .brief-form__textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg-primary);
  }
  .brief-form__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.45;
    cursor: pointer;
    max-width: 36rem;
    margin-top: 1rem;
  }
  .brief-form__consent input { margin-top: 0.25rem; flex-shrink: 0; accent-color: var(--accent); }
  .brief-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--accent);
    color: var(--accent-text);
    font-weight: 600;
    font-size: 1rem;
    border-radius: var(--radius-full);
    cursor: pointer;
    align-self: flex-start;
    transition: background-color var(--duration-fast) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .brief-form__submit:hover { background: var(--accent-hover); transform: translateY(-2px); }
  .brief-form__submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .brief-form__status { font-size: 0.875rem; min-height: 1.25rem; }
  .brief-form__status[data-state='success'] { color: var(--success); }
  .brief-form__status[data-state='error'] { color: var(--error); }
</style>

<script>
  function initBriefForm() {
    const form = document.querySelector<HTMLFormElement>('[data-brief-form]');
    if (!form || form.dataset.bound === '1') return;
    form.dataset.bound = '1';

    const variant = form.dataset.briefVariant || 'website';
    const status = form.querySelector('[data-brief-status]') as HTMLElement | null;
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const submitLabel = submit?.querySelector('.brief-form__submit-label');
    const accessKey = (form.elements.namedItem('access_key') as HTMLInputElement | null)?.value;
    const redirectUrl = (form.elements.namedItem('redirect') as HTMLInputElement | null)?.value;

    // Autosave to localStorage so users don't lose long answers
    const saveKey = `brief-draft-${variant}`;
    try {
      const saved = JSON.parse(localStorage.getItem(saveKey) || '{}');
      Object.entries(saved).forEach(([k, v]) => {
        const el = form.elements.namedItem(k) as HTMLInputElement | HTMLTextAreaElement | null;
        if (el && typeof v === 'string') el.value = v;
      });
    } catch { /* ignore corrupt JSON */ }

    const persist = () => {
      const fd = new FormData(form);
      const obj: Record<string, string> = {};
      fd.forEach((v, k) => {
        if (typeof v === 'string' && k !== 'access_key' && k !== 'subject' && k !== 'from_name' && k !== 'redirect' && k !== 'botcheck' && k !== 'consent') {
          obj[k] = v;
        }
      });
      try { localStorage.setItem(saveKey, JSON.stringify(obj)); } catch { /* ignore quota */ }
    };
    form.addEventListener('input', persist);

    form.addEventListener('submit', async (e) => {
      if (!status || !submit) return;
      e.preventDefault();

      const formData = new FormData(form);
      if (formData.get('botcheck')) return;

      submit.disabled = true;
      const originalLabel = submitLabel?.textContent ?? 'Submit';
      if (submitLabel) submitLabel.textContent = 'Sending…';

      // Placeholder key — pretend success and redirect
      if (!accessKey || accessKey.includes('REPLACE_WITH')) {
        await new Promise((r) => setTimeout(r, 500));
        try { localStorage.removeItem(saveKey); } catch { /* ignore */ }
        if (redirectUrl) { window.location.assign(redirectUrl); return; }
        if (submitLabel) submitLabel.textContent = originalLabel;
        submit.disabled = false;
        return;
      }

      try {
        const res = await fetch(form.action, { method: 'POST', body: formData });
        if (res.ok) {
          try { localStorage.removeItem(saveKey); } catch { /* ignore */ }
          if (redirectUrl) { window.location.assign(redirectUrl); return; }
          status.dataset.state = 'success';
          status.textContent = 'Brief received. Talk soon.';
          form.reset();
        } else {
          status.dataset.state = 'error';
          status.textContent = 'Something went wrong sending the brief. Please try again or email us.';
        }
      } catch {
        status.dataset.state = 'error';
        status.textContent = 'Network error. Please try again.';
      } finally {
        submit.disabled = false;
        if (submitLabel) submitLabel.textContent = originalLabel;
      }
    });
  }
  initBriefForm();
  document.addEventListener('astro:page-load', initBriefForm);
</script>
