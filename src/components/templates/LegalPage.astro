---
/**
 * LegalPage — generic template for static legal pages.
 * Variants: 'privacy' | 'cookies' | 'terms'
 *
 * Pulls content from i18n (with EN fallback). Renders sticky TOC + sections.
 */
import { getTranslations, getLocalizedPath, formatDate, type Language } from '@/i18n/utils';
import Breadcrumb from '@/components/layout/Breadcrumb.astro';

interface Props {
  lang: Language;
  variant: 'privacy' | 'cookies' | 'terms';
}
const { lang, variant } = Astro.props;
const all = getTranslations(lang) as any;
const enAll = getTranslations('en') as any;
const data = all?.legal_pages?.[variant] ?? enAll.legal_pages[variant];
const common = all?.legal_pages?.common ?? enAll.legal_pages.common;

const homeHref = getLocalizedPath('home', lang);

// Slug-ify section title for in-page anchors
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const sections = (data.sections as Array<{ title: string; body: string }>).map((s) => ({
  ...s,
  id: slugify(s.title),
}));
---

<Breadcrumb lang={lang} items={[{ name: data.h1 }]} visualHidden={true} />

<section class="legal-hero">
  <div class="container-x legal-hero__inner">
    <a href={homeHref} class="legal-hero__back" data-reveal>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {common.back_home}
    </a>
    <p class="legal-hero__kicker" data-reveal>— {data.kicker}</p>
    <h1 class="legal-hero__h1 text-balance" data-reveal data-reveal-delay="0.1">{data.h1}</h1>
    <p class="legal-hero__lead" data-reveal data-reveal-delay="0.2">{data.lead}</p>
    <p class="legal-hero__updated" data-reveal data-reveal-delay="0.3">
      {common.last_updated}: <time datetime={data.last_updated}>{formatDate(data.last_updated, lang)}</time>
    </p>
  </div>
</section>

<section class="legal-body section-y-sm">
  <div class="container-x legal-body__inner">
    {/* TOC */}
    <aside class="legal-toc" aria-label="Table of contents" data-reveal>
      <p class="legal-toc__label">{common.table_of_contents}</p>
      <ol class="legal-toc__list">
        {sections.map((s, i) => (
          <li>
            <a href={`#${s.id}`}>
              <span class="legal-toc__num">{(i + 1).toString().padStart(2, '0')}</span>
              <span>{s.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </aside>

    {/* Content */}
    <article class="legal-content" data-reveal-stagger data-stagger-interval="0.05">
      {sections.map((s, i) => (
        <section id={s.id} class="legal-section">
          <header class="legal-section__head">
            <span class="legal-section__num">/{(i + 1).toString().padStart(2, '0')}</span>
            <h2 class="legal-section__title">{s.title}</h2>
          </header>
          <div class="legal-section__body">
            {s.body.split('\n').map((para) => para.trim() && <p>{para}</p>)}
          </div>
        </section>
      ))}
    </article>
  </div>
</section>

<style>
  .legal-hero {
    padding-top: calc(var(--header-height) + clamp(2rem, 6vw, 4rem));
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  .legal-hero__inner { max-width: 50rem; }
  .legal-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    transition: color var(--duration-fast) var(--ease-out), gap var(--duration-base) var(--ease-out);
  }
  .legal-hero__back:hover { color: var(--accent); gap: 0.625rem; }
  .legal-hero__kicker { font-size: 0.875rem; color: var(--accent); font-weight: 500; margin-bottom: 1rem; }
  .legal-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 2.5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .legal-hero__lead {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 42rem;
    margin-bottom: 1.5rem;
  }
  .legal-hero__updated {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding: 0.5rem 0.875rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  /* Body grid */
  .legal-body__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 4rem);
  }
  @media (min-width: 1024px) { .legal-body__inner { grid-template-columns: 16rem 1fr; align-items: start; } }

  /* TOC */
  .legal-toc {
    padding: 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  @media (min-width: 1024px) { .legal-toc { position: sticky; top: calc(var(--header-height) + 1rem); } }
  .legal-toc__label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .legal-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    counter-reset: toc;
  }
  .legal-toc__list a {
    display: flex;
    gap: 0.625rem;
    padding: 0.375rem 0;
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.4;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .legal-toc__list a:hover { color: var(--accent); }
  .legal-toc__num {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  /* Sections */
  .legal-content { display: flex; flex-direction: column; gap: 3rem; }
  .legal-section { scroll-margin-top: calc(var(--header-height) + 2rem); }
  .legal-section__head { margin-bottom: 1.25rem; }
  .legal-section__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .legal-section__title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 1.2rem + 0.7vw, 1.75rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .legal-section__body { display: flex; flex-direction: column; gap: 1rem; max-width: 42rem; }
  .legal-section__body p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    white-space: pre-line;
  }
</style>
