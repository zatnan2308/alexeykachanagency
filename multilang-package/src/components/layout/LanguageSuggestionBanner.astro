---
/**
 * LanguageSuggestionBanner.astro
 * ------------------------------
 * Non-intrusive banner that suggests a language switch based on browser preferences.
 *
 * IMPORTANT: This is a UI suggestion only — NOT an automatic redirect.
 * Auto-redirects break Google's ability to crawl all language versions.
 * Always let users explicitly choose.
 *
 * Behavior:
 *  - Detects browser language on client side
 *  - Shows banner ONLY if browser preference differs from current page language
 *  - Remembers user's choice in localStorage (no banner shown again)
 *  - Banner can be dismissed via "No" or "Later" buttons
 *  - Hidden if user has already made a choice
 *
 * Place this once in BaseLayout.astro (NOT on every page).
 */

import { useTranslations, getLangFromUrl, type Language } from '@/i18n/utils';
import { LANGUAGE_NAMES } from '@/i18n/slugs';

const currentLang: Language = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Pass all language data to the client for dynamic suggestion building
const languageData = LANGUAGE_NAMES;
const currentPath = Astro.url.pathname;
---

<div
  class="lang-banner"
  role="region"
  aria-label="Language suggestion"
  data-current-lang={currentLang}
  data-current-path={currentPath}
  data-language-data={JSON.stringify(languageData)}
  hidden
>
  <div class="lang-banner__inner">
    <div class="lang-banner__content">
      <span class="lang-banner__flag" data-flag aria-hidden="true">🌐</span>
      <div class="lang-banner__text">
        <p class="lang-banner__title" data-title>
          {t('languages.suggest_banner.title').replace('{language}', '___')}
        </p>
        <p class="lang-banner__subtitle" data-subtitle>
          {t('languages.suggest_banner.subtitle').replace('{language}', '___')}
        </p>
      </div>
    </div>
    <div class="lang-banner__actions">
      <a
        href="#"
        class="lang-banner__btn lang-banner__btn--primary"
        data-action="switch"
      >
        {t('languages.suggest_banner.yes')}
      </a>
      <button
        type="button"
        class="lang-banner__btn lang-banner__btn--secondary"
        data-action="dismiss"
      >
        {t('languages.suggest_banner.no')}
      </button>
      <button
        type="button"
        class="lang-banner__close"
        aria-label={t('common.close')}
        data-action="close"
      >
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 4l8 8M12 4l-8 8" />
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .lang-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    max-width: min(calc(100vw - 2rem), 36rem);
    background: var(--bg-secondary, #131316);
    border: 1px solid var(--border, #27272a);
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    z-index: 80;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    animation: lang-banner-in 350ms ease-out;
  }

  .lang-banner[hidden] {
    display: none;
  }

  .lang-banner__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  @media (min-width: 640px) {
    .lang-banner__inner {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }
  }

  .lang-banner__content {
    display: flex;
    gap: 0.875rem;
    align-items: center;
    flex: 1;
  }

  .lang-banner__flag {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .lang-banner__text {
    flex: 1;
    min-width: 0;
  }

  .lang-banner__title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary, #f5f5f7);
    line-height: 1.4;
  }

  .lang-banner__subtitle {
    margin: 0.125rem 0 0;
    font-size: 0.8125rem;
    color: var(--text-muted, #71717a);
    line-height: 1.4;
  }

  .lang-banner__actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  .lang-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background-color 150ms ease, border-color 150ms ease, color 150ms ease;
    white-space: nowrap;
  }

  .lang-banner__btn--primary {
    background-color: var(--accent, #d7ff3d);
    color: var(--accent-text, #0a0a0b);
  }

  .lang-banner__btn--primary:hover,
  .lang-banner__btn--primary:focus-visible {
    background-color: var(--accent-hover, #c5ff1f);
  }

  .lang-banner__btn--secondary {
    background: transparent;
    color: var(--text-secondary, #a1a1aa);
    border-color: var(--border, #27272a);
  }

  .lang-banner__btn--secondary:hover,
  .lang-banner__btn--secondary:focus-visible {
    color: var(--text-primary, #f5f5f7);
    border-color: var(--text-secondary, #a1a1aa);
  }

  .lang-banner__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: none;
    color: var(--text-muted, #71717a);
    cursor: pointer;
    border-radius: 0.375rem;
    transition: color 150ms ease, background-color 150ms ease;
  }

  .lang-banner__close:hover,
  .lang-banner__close:focus-visible {
    color: var(--text-primary, #f5f5f7);
    background-color: var(--bg-tertiary, #1c1c20);
  }

  .lang-banner__close svg {
    width: 1rem;
    height: 1rem;
  }

  .lang-banner__btn:focus-visible,
  .lang-banner__close:focus-visible {
    outline: 2px solid var(--accent, #d7ff3d);
    outline-offset: 2px;
  }

  @keyframes lang-banner-in {
    from {
      opacity: 0;
      transform: translate(-50%, 1rem);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-banner {
      animation: none;
    }

    .lang-banner__btn,
    .lang-banner__close {
      transition: none;
    }
  }
</style>

<script>
  import {
    LANGUAGES,
    suggestLanguageFromBrowser,
    getEquivalentUrl,
    type Language,
  } from '@/i18n/utils';

  const STORAGE_KEY = 'lang-banner-dismissed';
  const STORAGE_VERSION = '1'; // bump if banner content changes significantly

  function initLanguageBanner() {
    const banner = document.querySelector('.lang-banner') as HTMLElement | null;
    if (!banner) return;

    // Already dismissed? Don't show again.
    const dismissed = localStorage.getItem(STORAGE_KEY);
    if (dismissed === STORAGE_VERSION) return;

    const currentLang = banner.dataset.currentLang as Language;
    const currentPath = banner.dataset.currentPath as string;

    // Check if browser suggests a different language
    const suggested = suggestLanguageFromBrowser(currentLang);
    if (!suggested) return;

    // Get language data
    let languageData: Record<string, { native: string; flag: string }>;
    try {
      languageData = JSON.parse(banner.dataset.languageData || '{}');
    } catch {
      return;
    }

    const suggestedData = languageData[suggested];
    if (!suggestedData) return;

    // Update banner content with suggested language name
    const titleEl = banner.querySelector('[data-title]');
    const subtitleEl = banner.querySelector('[data-subtitle]');
    const flagEl = banner.querySelector('[data-flag]');
    const switchLink = banner.querySelector(
      '[data-action="switch"]'
    ) as HTMLAnchorElement | null;

    if (titleEl) {
      titleEl.textContent = titleEl.textContent?.replace(
        '___',
        suggestedData.native
      ) || '';
    }
    if (subtitleEl) {
      subtitleEl.textContent = subtitleEl.textContent?.replace(
        '___',
        suggestedData.native
      ) || '';
    }
    if (flagEl) {
      flagEl.textContent = suggestedData.flag;
    }
    if (switchLink) {
      switchLink.href = getEquivalentUrl(currentPath, suggested);
      switchLink.setAttribute('hreflang', suggested);
      switchLink.setAttribute('lang', suggested);
    }

    // Show banner
    banner.removeAttribute('hidden');

    // Dismiss handler — saves preference, hides banner
    const dismiss = () => {
      try {
        localStorage.setItem(STORAGE_KEY, STORAGE_VERSION);
      } catch {
        // localStorage not available (private mode, etc.) — silently ignore
      }
      banner.setAttribute('hidden', '');
    };

    banner.querySelector('[data-action="dismiss"]')?.addEventListener('click', dismiss);
    banner.querySelector('[data-action="close"]')?.addEventListener('click', dismiss);

    // Switch button — also dismisses, then navigation happens via href
    switchLink?.addEventListener('click', () => {
      try {
        localStorage.setItem(STORAGE_KEY, STORAGE_VERSION);
      } catch {}
    });
  }

  initLanguageBanner();
  document.addEventListener('astro:after-swap', initLanguageBanner);
</script>
